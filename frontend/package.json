{
  "name": "ai-interview-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit && vite build",
    "generate:oj-index": "node scripts/generate-oj-completion-index.mjs",
    "check:oj-index": "node scripts/generate-oj-completion-index.mjs --check",
    "test:oj-index": "node scripts/test-oj-completion-index.mjs",
    "test:completion": "vitest run src/completion/oj-completion.worker.test.ts",
    "preview": "vite preview --host 0.0.0.0 --port 4173"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@repomix/tree-sitter-wasms": "^0.1.17",
    "lucide": "^1.23.0",
    "monaco-editor": "^0.55.1",
    "web-tree-sitter": "^0.25.10"
  }
}

APP_ENV=local
HTTP_ADDR=:8080
LOG_LEVEL=info

DATABASE_URL=postgres://ai_interview:ai_interview@localhost:5432/ai_interview?sslmode=disable
REDIS_ADDR=localhost:6379
INTERVIEW_EVENTS_STREAM=interview:events
INTERVIEW_DEAD_LETTER_STREAM=interview:events:dead
ENABLE_EMBEDDED_WORKER=false
CODING_JUDGE_ENABLED=false
CODING_JUDGE_BATCH_SIZE=4
CODING_JUDGE_MODE=disabled
CODING_JUDGE_DOCKER_BINARY=docker
CODING_JUDGE_CONTAINER_PREFIX=ai-interview-judge
CODING_JUDGE_GO_IMAGE=golang:1.26-alpine
CODING_JUDGE_JAVA_IMAGE=eclipse-temurin:21-jdk-alpine
CODING_JUDGE_PYTHON_IMAGE=python:3.13-alpine
CODING_JUDGE_JAVASCRIPT_IMAGE=node:22-alpine
CODING_JUDGE_TYPESCRIPT_IMAGE=denoland/deno:alpine-2.1.4
CODING_JUDGE_CPP_IMAGE=gcc:14-alpine
CODING_JUDGE_NATIVE_GO=go
CODING_JUDGE_NATIVE_JAVA=java
CODING_JUDGE_NATIVE_JAVAC=javac
CODING_JUDGE_NATIVE_PYTHON=python3
CODING_JUDGE_NATIVE_NODE=node
CODING_JUDGE_NATIVE_DENO=deno
CODING_JUDGE_NATIVE_GPP=g++
CODING_JUDGE_TIMEOUT_SECONDS=5
CODING_JUDGE_MEMORY=128m
CODING_JUDGE_CPUS=0.5
MINIO_ENDPOINT=localhost:9000
SKILLS_DIR=skills
CONTEXT_TOKEN_BUDGET=12000
AI_RUNTIME_URL=http://localhost:8090
PYTHON_RUNTIME_IMAGE=ai-interview-python-runtime:local
PROVIDER_KEY_ENCRYPTION_SECRET=

AUTH_DISABLED=false
JWT_ACCESS_SECRET=local-dev-access-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
ROOT_EMAIL=root@example.local
ROOT_PASSWORD=RootChangeMe123!
ROOT_DISPLAY_NAME=Root

LLM_TIMEOUT_SECONDS=30
MEMORY_DB_PATH=data/runtime_memory.sqlite3

POSTGRES_IMAGE=pgvector/pgvector:pg16
REDIS_IMAGE=redis:7-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=ai_interview
MINIO_ROOT_PASSWORD=ai_interview_secret

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_ENDPOINT_PATH=/chat/completions
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=

OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_CHAT_ENDPOINT_PATH=/chat/completions
OPENAI_COMPATIBLE_CHAT_MODEL=
OPENAI_COMPATIBLE_API_KEY=

EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
